# MIMO API (OpenAI 兼容, tp- 前缀 Token Plan)
MIMO_API_KEY=your_mimo_key_here
# Token Plan (tp-) key 使用 token-plan-cn 端点；如用其它类型 key 请按需修改
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# 执行器 (OpenCode) 可选配置
# OPENCODE_CMD=opencode
# OPENCODE_TIMEOUT=300
# 设为 0 可关闭 --auto 无确认执行（更安全）
# OPENCODE_AUTO_APPROVE=1
